{
	"name": "devmonowar/advanced-testimonial",
	"description": "Professional testimonial and customer review management for WordPress.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"version": "2.0.5",
	"require": {
		"php": ">=7.4"
	},
	"require-dev": {
		"squizlabs/php_codesniffer": "^3.9",
		"wp-coding-standards/wpcs": "^3.1",
		"phpcompatibility/phpcompatibility-wp": "^2.1"
	},
	"autoload": {
		"psr-4": {
			"AdvancedTestimonial\\": "includes/",
			"AdvancedTestimonial\\Admin\\": "admin/",
			"AdvancedTestimonial\\Frontend\\": "frontend/",
			"AdvancedTestimonial\\Shortcode\\": "shortcode/",
			"AdvancedTestimonial\\Blocks\\": "blocks/"
		}
	},
	"config": {
		"optimize-autoloader": true,
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"scripts": {
		"lint": "phpcs",
		"lint:fix": "phpcbf"
	}
}
